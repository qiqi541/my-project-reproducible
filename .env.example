# Kafka exposed on the Ubuntu VM. Keep localhost when the browser and Docker
# commands run inside the same VM.
KAFKA_HOST=localhost

# Simulated WAF switch used by the ablation experiment.
WAF_ENABLED=true

# Dashboard credentials. Change these before use.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=replace-with-a-long-random-value

# Continuous demo mode settings.
PROBE_INTERVAL_SECONDS=1.0
PROBE_CYCLE_PAUSE_SECONDS=5.0

